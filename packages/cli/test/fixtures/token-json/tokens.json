{
  "color": {
    "$type": "color",
    "brand": {
      "500": { "$value": "#3B82F6" },
      "600": { "$value": "#2563EB" }
    },
    "accent": { "$value": "#F59E0B" }
  },
  "space": {
    "$type": "dimension",
    "sm": { "$value": "8px" },
    "md": { "$value": "1rem" },
    "lg": { "$value": "{space.md}" },
    "xl": { "$value": "2.25rem" }
  },
  "alias-cycle": {
    "a": { "$type": "dimension", "$value": "{alias-cycle.b}" },
    "b": { "$type": "dimension", "$value": "{alias-cycle.a}" }
  }
}
